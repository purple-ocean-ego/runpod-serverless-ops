# RunPod S3 Storage Credentials
# RunPodのダッシュボード「Settings」 -> 「S3 Access Keys」より取得してください。
RUNPOD_S3_ACCESS_KEY="ここにアクセスキーを入力"
RUNPOD_S3_SECRET_KEY="ここにシークレットキーを入力"
RUNPOD_S3_ENDPOINT="ここにエンドポイントURLを入力"
RUNPOD_S3_REGION="ここにリージョン名を入力 (例: eu-cz-1)"

# ボリュームID（ダッシュボードの Storage ページで確認できる Bucket name）
RUNPOD_S3_BUCKET="ここにボリュームIDを入力"
